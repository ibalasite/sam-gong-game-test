{
  "compilerOptions": {
    "target": "ES2015",
    "module": "commonjs",
    "lib": ["ES2015", "DOM"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noImplicitAny": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "paths": {
      "cc": ["./typings/cc.d.ts"]
    }
  },
  "include": ["assets/scripts/**/*", "tests/**/*"],
  "exclude": ["node_modules"]
}
