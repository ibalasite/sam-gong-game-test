# Colyseus Server
PORT=2567
NODE_ENV=development

# Security
JWT_SECRET=your-256-bit-secret-here
COLYSEUS_LOBBY_CHANNEL=$lobby

# Database (Production — SQLite used in pilot)
DATABASE_URL=postgresql://user:password@localhost:5432/samgong
SQLITE_DB_PATH=./data/samgong.db

# Game Config
MAX_ROOMS=100
MAX_PLAYERS_PER_ROOM=6
RECONNECT_WINDOW_SECONDS=60

# Monitoring (optional)
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project

# CORS
ALLOWED_ORIGINS=http://localhost:7456,https://your-cocos-client.example.com
