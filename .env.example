# =============================================================================
# Sam Gong (三公) - Environment Variables Template
# =============================================================================
# Copy this file to .env and fill in the values:
#   cp .env.example .env
#
# NEVER commit .env to git. It is listed in .gitignore.
# Real production secrets are managed by the devsop-secrets pipeline.
# =============================================================================

# --- Application ---
NODE_ENV=development
LOG_LEVEL=debug
TZ=Asia/Taipei

# --- Colyseus Game Server ---
PORT=2567

# --- REST API Server ---
API_PORT=3000

# --- Database (PostgreSQL) ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=sam_gong
DB_USER=sam_gong_app
DB_PASSWORD=dev_password_change_me
# Connection pool
DB_POOL_MIN=2
DB_POOL_MAX=10

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=dev_redis_password

# --- JWT Authentication (RS256) ---
# Generate keys:
#   openssl genrsa -out keys/private.pem 4096
#   openssl rsa -in keys/private.pem -pubout -out keys/public.pem
JWT_PRIVATE_KEY_PATH=./keys/private.pem
JWT_PUBLIC_KEY_PATH=./keys/public.pem
JWT_ALGORITHM=RS256
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# --- OTP / Age Verification (Taiwan regulation) ---
OTP_API_KEY=your_otp_provider_api_key_here
OTP_API_URL=https://api.otp-provider.com

# --- Anti-Addiction (Taiwan regulations UTC+8) ---
ANTI_ADDICTION_ENABLED=true
# Daily play time limit in minutes (Taiwan regulation: 120 min for minors)
ANTI_ADDICTION_DAILY_LIMIT_MINUTES=120
# Curfew: minors cannot play 22:00-08:00 (UTC+8)
ANTI_ADDICTION_CURFEW_START=22
ANTI_ADDICTION_CURFEW_END=8

# --- Game Settings ---
GAME_ROOMS_MAX=100
RAKE_RATE=0.05
RAKE_MIN=1
COLYSEUS_MONITOR_ENABLED=true

# --- Rate Limiting (NFR-19) ---
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# --- CORS ---
CORS_ORIGIN=http://localhost:3001

# --- pgAdmin (local dev only) ---
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=admin
